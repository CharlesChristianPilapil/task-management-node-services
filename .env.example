NODE_ENV=development
PORT=3000
HOST=0.0.0.0
APP_URL=http://localhost:3000

# Laravel API base URL (include /api if that is your prefix)
LARAVEL_API_URL=http://localhost:8000/api

# Must match JWT_SECRET in the Laravel .env
JWT_SECRET=

# Shared secret for Laravel <-> Node internal requests
INTERNAL_SERVICE_KEY=

# Comma-separated allowed origins, or * for all
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Gmail — use an app password (not your normal Gmail password)
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-gmail-app-password

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=30
RATE_LIMIT_PER_USER_MAX=5
RATE_LIMIT_PER_USER_WINDOW_MS=3600000

# Optional — only when this service owns a database
DATABASE_URL=