NODE_ENV=development
PORT=3000
HOST=0.0.0.0
APP_URL=http://localhost:3000

# Laravel API base URL (include /api if that is your prefix)
LARAVEL_API_URL=http://localhost:8000/api

# Must match JWT_SECRET in the Laravel .env
JWT_SECRET=

# Shared secret for Laravel <-> Node internal requests
INTERNAL_SERVICE_KEY=

# Comma-separated allowed origins, or * for all
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8000

# Gmail — use an app password (not your normal Gmail password)
# Render production: SMTP disabled — leave EMAIL_USER/EMAIL_PASS unset or use placeholders
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-gmail-app-password

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=30
RATE_LIMIT_PER_USER_MAX=5
RATE_LIMIT_PER_USER_WINDOW_MS=3600000

# Cron scheduler
# Local dev: CRON_ENABLED=true (in-process node-cron)
# Render production: CRON_ENABLED=false (cron disabled; external triggers not configured)
# Optional external cron via cron-job.org when CRON_ENABLED=false:
#   POST /api/cron/daily-digest       — schedule: 0 8 * * *
#   POST /api/cron/deadline-reminder — schedule: 0 */2 * * *
#   POST /api/cron/task-cleanup      — schedule: 0 0 * * *
#   Header: X-Service-Key: <INTERNAL_SERVICE_KEY>
CRON_ENABLED=true
CRON_TIMEZONE=UTC
CRON_RETRY_ATTEMPTS=3
CRON_RETRY_DELAY_MS=1000
CRON_DAILY_DIGEST=0 8 * * *
CRON_DEADLINE_REMINDER=0 */2 * * *
CRON_TASK_CLEANUP=0 0 * * *